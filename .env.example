# Telegram Bot Configuration
# ============================

# Сделайте следующие шаги для настройки Telegram уведомлений:
#
# 1. Создайте бота через BotFather в Telegram (@BotFather)
#    - Отправьте команду /newbot
#    - Следуйте инструкциям
#    - Скопируйте полученный token
#
# 2. Получите Chat ID:
#    - Напишите боту сообщение
#    - Откройте в браузере: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    - Найдите chat.id в ответе
#
# 3. Заполните значения ниже:

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Пример:
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=1234567890
